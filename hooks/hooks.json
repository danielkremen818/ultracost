{
  "description": "ultracost: inject the model-routing policy at session start, set up the live cost HUD statusline on first run, hard-gate every dynamic-workflow launch with a cost estimate (PreToolUse on the Workflow tool), and auto-run the closed loop (reconcile + calibrate + ledger) on Stop after a workflow finishes.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/templates/hooks/reinject.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/templates/hooks/hud-setup.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/templates/hooks/workflow-gate.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/templates/hooks/loop-autorun.mjs\""
          }
        ]
      }
    ]
  }
}
